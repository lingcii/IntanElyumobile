{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "NIXPACKS",
        "buildCommand": "composer install --no-dev --optimize-autoloader"
    },
    "deploy": {
        "startCommand": "php artisan config:clear && php artisan route:cache && php artisan serve --host=0.0.0.0 --port=$PORT",
        "healthcheckPath": "/api/public/test",
        "restartPolicyType": "ON_FAILURE"
    }
}
